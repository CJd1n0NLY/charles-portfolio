generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id            String         @id @default(cuid())
  slug          String         @unique
  chapter       String         // "ACADEMIC" | "INTERNSHIP" | "CAPSTONE" | "PERSONAL"
  title         String
  tagline       String
  status        String         @default("DRAFT") // "DRAFT" | "PUBLISHED"
  order         Int            @default(0)
  heroImageUrl  String?
  heroImageAlt  String?        // Added per accessibility guardrails
  liveUrl       String?
  repoUrl       String?
  problem       String?        
  approach      String?        
  outcome       String?        
  techStack     String?        // Stored as comma-separated string for SQLite compatibility
  challenges    Challenge[]
  gallery       GalleryImage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Challenge {
  id          String  @id @default(cuid())
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  description String  
  order       Int     @default(0)
}

model GalleryImage {
  id          String  @id @default(cuid())
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  url         String
  altText     String  // Added per accessibility guardrails
  caption     String?
  order       Int     @default(0)
}

model ChapterIntro {
  id          String   @id @default(cuid())
  chapter     String   @unique // "ACADEMIC" | "INTERNSHIP" | "CAPSTONE" | "PERSONAL"
  heading     String
  narrative   String   
}

model Skill {
  id       String  @id @default(cuid())
  category String  // "LANGUAGE" | "FRAMEWORK" | "DATABASE" | "TOOL" | "METHODOLOGY"
  name     String
  order    Int     @default(0)
}

model WorkExperience {
  id               String    @id @default(cuid())
  company          String
  role             String
  location         String?
  startDate        DateTime
  endDate          DateTime?
  responsibilities String    // Stored as a JSON string array for SQLite compatibility
  order            Int       @default(0)
}

model Certificate {
  id           String    @id @default(cuid())
  title        String
  issuer       String
  dateIssued   DateTime?
  imageUrl     String
  reviewStatus String    @default("PENDING") // "PENDING" | "LOOKS_VALID" | "FLAGGED_FOR_REVIEW"
  reviewNotes  String?   
  order        Int       @default(0)
}

model Education {
  id        String  @id @default(cuid())
  school    String
  degree    String
  section   String?
  honors    String?
  startYear Int
  endYear   Int
}

model SiteSettings {
  id              String  @id @default("global")
  heroPortraitUrl String?
  aboutPhotoUrl   String?
}